{
  "name": "@table-q/units",
  "version": "1.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/table-q/units.git",
    "directory": "packages/units"
  },
  "homepage": "https://table-q.github.io/units/",
  "type": "module",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "bigint",
    "rational",
    "exact-arithmetic",
    "financial",
    "math",
    "money",
    "currency",
    "units",
    "rounding",
    "precision"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:ui": "vitest --ui --coverage",
    "test:performance": "vitest bench",
    "check:lint": "biome check --error-on-warnings src/",
    "check:types": "tsc --noEmit",
    "format": "biome check --write src/",
    "ci": "npx npm-run-all check:lint check:types test build"
  },
  "dependencies": {
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "25.6.0",
    "@vitest/coverage-istanbul": "4.1.4",
    "@vitest/ui": "4.1.4",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  }
}
