{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2020",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["vitest/globals", "node"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@table-q/units": ["./src/index"],
      "unit": ["./src/lib/unit"],
      "util/*": ["./src/lib/util/*"],
      "value": ["./src/lib/value"],
      "value/*": ["./src/lib/value/*"]
    }
  },
  "include": ["src/**/*.ts", "vitest.config.ts", "jest.setup.ts"],
  "exclude": ["node_modules", "dist"]
}
